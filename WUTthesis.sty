% Front matter uses Roman page numbers and suppresses running headers.
\newcommand{\WUTfrontmatter}{%
  \frontmatter
  \let\cleardoublepage\clearpage
  \pagestyle{wut@frontmatter}%
  \pagenumbering{Roman}%
  \setcounter{page}{1}%
  \WUT@setfrontmatterheadings
}

% Main matter switches back to thesis headers and Arabic numbering.
\newcommand{\WUTmainmatter}{%
  \mainmatter
  \pagestyle{wut@mainmatter}%
  \WUT@setmainmatterheadings
  \WUT@bodyfont
}

% Back matter keeps the body page style but centers chapter titles.
\newcommand{\WUTbackmatter}{%
  \backmatter
  \pagestyle{wut@mainmatter}%
  \WUT@setbackmatterheadings
}

% Keep TOC spacing in one place so school-required adjustments stay centralized.
\newcommand{\WUTtableofcontents}{%
  \clearpage
  \addcontentsline{toc}{chapter}{目次}%
  \addtocontents{toc}{\protect\setlength{\baselineskip}{20pt}}%
  \addtocontents{toc}{\protect\setlength{\parskip}{0pt}}%
  \tableofcontents
}

